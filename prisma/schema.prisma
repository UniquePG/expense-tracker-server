// ============================================================
// SplitWiseMint — Complete Prisma Schema (Corrected & Final)
// Version: 2.0.0  |  Date: March 2026
// All issues from audit resolved. Production-ready.
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum FriendshipStatus {
  PENDING
  ACCEPTED
  REJECTED
  BLOCKED
}

enum SplitType {
  EQUAL
  PERCENTAGE
  EXACT
  SHARES
}

enum ExpenseType {
  PERSONAL   // expense not linked to any group
  GROUP      // expense linked to a group
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER        // between own accounts
  SETTLEMENT_OUT  // money sent to settle a split
  SETTLEMENT_IN   // money received as settlement
}

enum AccountType {
  CASH
  BANK
  CREDIT_CARD
  WALLET
  UPI
}

// NEW: for settlement payment tracking
enum SettlementStatus {
  PENDING     // initiated, waiting for receiver confirmation
  CONFIRMED   // receiver confirmed receipt
  REJECTED    // receiver rejected (e.g., wrong amount)
  CANCELLED   // sender cancelled before confirmation
}

// NEW: how payment was made
enum PaymentMethod {
  UPI
  CASH
  BANK_TRANSFER
  CARD
  OTHER
}

// NEW: notification types for deep-linking and categorization
enum NotificationType {
  FRIEND_REQUEST
  FRIEND_ACCEPTED
  FRIEND_REJECTED
  EXPENSE_ADDED
  EXPENSE_UPDATED
  EXPENSE_DELETED
  SPLIT_ASSIGNED         // you were added to a split
  SETTLEMENT_RECEIVED    // someone initiated settlement to you
  SETTLEMENT_CONFIRMED   // your settlement was confirmed
  SETTLEMENT_REJECTED    // your settlement was rejected
  SETTLEMENT_REMINDER    // reminder to pay a debt
  GROUP_INVITE           // added to a group
  GROUP_EXPENSE_ADDED    // new expense in your group
  BUDGET_ALERT_50        // 50% of budget used
  BUDGET_ALERT_80        // 80% of budget used
  BUDGET_ALERT_100       // budget fully used / exceeded
  LOW_BALANCE            // account balance below threshold
  SYSTEM                 // generic system notification
}

// NEW: budget period options
enum BudgetPeriod {
  WEEKLY
  MONTHLY
  YEARLY
}

// NEW: group lifecycle
enum GroupStatus {
  ACTIVE
  ARCHIVED
  DELETED
}

// NEW: group member lifecycle
enum MemberStatus {
  ACTIVE
  LEFT       // voluntarily left
  REMOVED    // removed by admin
}

// ============================================================
// USER
// ============================================================

model User {
  id              Int       @id @default(autoincrement())
  email           String    @unique
  password        String
  firstName       String
  lastName        String
  phone           String?   @unique
  avatar          String?                        // Cloudinary URL
  currency        String    @default("INR")      // default display currency
  pushToken       String?                        // FCM/APNS push notification token
  isEmailVerified Boolean   @default(false)
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // relations
  accounts             Account[]
  accountTransactions  AccountTransaction[]
  contacts             Contact[]              @relation("UserContactsOwner")
  linkedContacts       Contact[]              @relation("UserContactsLinked")
  expenses             Expense[]              // expenses this user paid
  expenseSplits        ExpenseSplit[]         // splits assigned to this user
  expenseComments      ExpenseComment[]
  groupsCreated        Group[]
  groupMemberships     GroupMember[]
  friendshipsInitiated Friendship[]           @relation("FriendshipsInitiated")
  friendshipsReceived  Friendship[]           @relation("FriendshipsReceived")
  settlementsPaid      Settlement[]           @relation("SettlementsPaid")
  settlementsReceived  Settlement[]           @relation("SettlementsReceived")
  invitesSent          Invite[]               @relation("InvitesSent")
  invitesReceived      Invite[]               @relation("InvitesReceived")
  notificationsReceived Notification[]        @relation("NotificationReceiver")
  notificationsSent    Notification[]         @relation("NotificationSender")
  categories           Category[]
  budgets              Budget[]
  refreshTokens        RefreshToken[]
  emailVerifications   EmailVerification[]

  @@map("users")
}

// ============================================================
// EMAIL VERIFICATION
// ============================================================

model EmailVerification {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
  @@map("email_verifications")
}

// ============================================================
// REFRESH TOKENS
// ============================================================

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

// ============================================================
// ACCOUNT
// A user's financial account (bank, UPI, cash, wallet, etc.)
// ============================================================

model Account {
  id          Int         @id @default(autoincrement())
  userId      Int
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String                              // e.g. "HDFC Savings", "GPay Wallet"
  type        AccountType
  balance     Decimal     @db.Decimal(12, 2)
  currency    String      @default("INR")
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  transactions AccountTransaction[]

  @@index([userId])
  @@unique([userId, name])              // user cannot have two accounts with same name
  @@map("accounts")
}

// ============================================================
// ACCOUNT TRANSACTION
// Personal financial ledger — income, expense, transfer, settlement
// This is the ONLY table for personal ledger entries.
// Expense splits are tracked separately via ExpenseSplit.
// ============================================================

model AccountTransaction {
  id              Int             @id @default(autoincrement())
  userId          Int
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId       Int
  account         Account         @relation(fields: [accountId], references: [id])
  type            TransactionType
  amount          Decimal         @db.Decimal(12, 2)  // always positive; direction from type
  description     String?
  categoryId      Int?                                 // for EXPENSE type entries
  category        Category?       @relation(fields: [categoryId], references: [id])
  incomeSource    String?                              // for INCOME type: "Salary", "Freelance", etc.
  expenseId       Int?                                 // link to expense if this is an expense payment
  expense         Expense?        @relation(fields: [expenseId], references: [id])
  settlementId    Int?                                 // link to settlement if type = SETTLEMENT_*
  settlement      Settlement?     @relation(fields: [settlementId], references: [id])
  toAccountId     Int?                                 // for TRANSFER: destination account
  transactionDate DateTime        @default(now())
  createdAt       DateTime        @default(now())

  @@index([userId])
  @@index([accountId])
  @@index([transactionDate])
  @@map("account_transactions")
}

// ============================================================
// CONTACTS (Non-app users that can be added to splits/groups)
// ============================================================

model Contact {
  id           Int      @id @default(autoincrement())
  ownerId      Int
  owner        User     @relation("UserContactsOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  name         String
  email        String?
  phone        String?
  avatar       String?  // optional avatar for contact
  linkedUserId Int?                                 // set when contact later joins app
  linkedUser   User?    @relation("UserContactsLinked", fields: [linkedUserId], references: [id])
  createdAt    DateTime @default(now())

  groupMembers  GroupMember[]
  expenseSplits ExpenseSplit[]

  @@index([ownerId])
  @@map("contacts")
}

// ============================================================
// FRIENDSHIPS
// ============================================================

model Friendship {
  id          Int              @id @default(autoincrement())
  requesterId Int
  requester   User             @relation("FriendshipsInitiated", fields: [requesterId], references: [id])
  addresseeId Int
  addressee   User             @relation("FriendshipsReceived", fields: [addresseeId], references: [id])
  status      FriendshipStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([requesterId, addresseeId])
  @@index([requesterId])
  @@index([addresseeId])
  @@map("friendships")
}

// ============================================================
// GROUPS
// ============================================================

model Group {
  id          Int         @id @default(autoincrement())
  name        String
  description String?
  image       String?     // Cloudinary URL
  createdBy   Int
  creator     User        @relation(fields: [createdBy], references: [id])
  status      GroupStatus @default(ACTIVE)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  members  GroupMember[]
  expenses Expense[]

  @@index([createdBy])
  @@map("groups")
}

// ============================================================
// GROUP MEMBERS
// Supports both app users (userId) and non-app contacts (contactId)
// Exactly one of userId or contactId must be set.
// ============================================================

model GroupMember {
  id        Int          @id @default(autoincrement())
  groupId   Int
  group     Group        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId    Int?
  user      User?        @relation(fields: [userId], references: [id])
  contactId Int?
  contact   Contact?     @relation(fields: [contactId], references: [id])
  isAdmin   Boolean      @default(false)
  status    MemberStatus @default(ACTIVE)
  joinedAt  DateTime     @default(now())
  leftAt    DateTime?    // set when status = LEFT or REMOVED

  @@index([groupId])
  @@index([userId])
  @@map("group_members")
}

// ============================================================
// CATEGORY
// userId = null means it's a system-default category visible to all users
// userId set means it's a user's custom category
// ============================================================

model Category {
  id       Int     @id @default(autoincrement())
  name     String
  icon     String?
  color    String?
  userId   Int?                         // null = system global default
  user     User?   @relation(fields: [userId], references: [id])
  isSystem Boolean @default(false)      // true = cannot be deleted, shipped with app

  expenses             Expense[]
  accountTransactions  AccountTransaction[]
  budgets              Budget[]

  @@map("categories")
}

// ============================================================
// EXPENSE
// Core expense record — personal or group
// ============================================================

model Expense {
  id          Int         @id @default(autoincrement())
  description String
  amount      Decimal     @db.Decimal(12, 2)
  currency    String      @default("INR")
  expenseDate DateTime    @default(now())
  splitType   SplitType
  expenseType ExpenseType
  paidById    Int
  paidBy      User        @relation(fields: [paidById], references: [id])
  categoryId  Int?
  category    Category?   @relation(fields: [categoryId], references: [id])
  groupId     Int?
  group       Group?      @relation(fields: [groupId], references: [id])
  notes       String?
  image       String?     // receipt image Cloudinary URL
  isDeleted   Boolean     @default(false)   // soft delete
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  splits              ExpenseSplit[]
  comments            ExpenseComment[]
  accountTransactions AccountTransaction[]

  @@index([paidById])
  @@index([groupId])
  @@index([expenseDate])
  @@map("expenses")
}

// ============================================================
// EXPENSE SPLIT
// One row per participant in an expense
// Either userId OR contactId must be set (not both, not neither)
// ============================================================

model ExpenseSplit {
  id         Int       @id @default(autoincrement())
  expenseId  Int
  expense    Expense   @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  userId     Int?
  user       User?     @relation(fields: [userId], references: [id])
  contactId  Int?
  contact    Contact?  @relation(fields: [contactId], references: [id])
  amount     Decimal   @db.Decimal(12, 2)
  percentage Decimal?  @db.Decimal(5, 2)  // stored for PERCENTAGE splits
  shares     Int?                           // stored for SHARES splits
  isPayer    Boolean   @default(false)      // true = this split belongs to the person who paid
  isSettled  Boolean   @default(false)
  settledAt  DateTime?
  createdAt  DateTime  @default(now())

  settlementSplits SettlementSplit[]

  @@index([expenseId])
  @@index([userId])
  @@map("expense_splits")
}

// ============================================================
// EXPENSE COMMENT
// Comments/notes on an expense by participants
// ============================================================

model ExpenseComment {
  id        Int      @id @default(autoincrement())
  expenseId Int
  expense   Expense  @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  text      String
  createdAt DateTime @default(now())

  @@index([expenseId])
  @@map("expense_comments")
}

// ============================================================
// SETTLEMENT
// Records a payment from one user to another to clear split debts
// ============================================================

model Settlement {
  id             Int             @id @default(autoincrement())
  fromUserId     Int
  fromUser       User            @relation("SettlementsPaid", fields: [fromUserId], references: [id])
  toUserId       Int
  toUser         User            @relation("SettlementsReceived", fields: [toUserId], references: [id])
  amount         Decimal         @db.Decimal(12, 2)
  currency       String          @default("INR")
  status         SettlementStatus @default(PENDING)
  method         PaymentMethod?
  utrReference   String?         // UPI transaction ID, bank ref, etc.
  notes          String?
  settlementDate DateTime        @default(now())
  confirmedAt    DateTime?       // set when status = CONFIRMED
  createdAt      DateTime        @default(now())

  settlementSplits SettlementSplit[]
  accountTransactions AccountTransaction[]

  @@index([fromUserId])
  @@index([toUserId])
  @@map("settlements")
}

// ============================================================
// SETTLEMENT SPLIT
// Junction: links a Settlement to the specific ExpenseSplits it clears
// ============================================================

model SettlementSplit {
  id             Int          @id @default(autoincrement())
  settlementId   Int
  settlement     Settlement   @relation(fields: [settlementId], references: [id], onDelete: Cascade)
  expenseSplitId Int
  expenseSplit   ExpenseSplit @relation(fields: [expenseSplitId], references: [id])
  amountCleared  Decimal      @db.Decimal(12, 2)

  @@index([settlementId])
  @@index([expenseSplitId])
  @@map("settlement_splits")
}

// ============================================================
// BUDGET
// User-defined spending limits per category per period
// categoryId = null means it's a total overall spending budget
// ============================================================

model Budget {
  id           Int          @id @default(autoincrement())
  userId       Int
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId   Int?
  category     Category?    @relation(fields: [categoryId], references: [id])
  name         String
  amount       Decimal      @db.Decimal(12, 2)
  periodType   BudgetPeriod
  startDate    DateTime                          // budget period starts here
  currency     String       @default("INR")
  alertAt50    Boolean      @default(true)       // notify when 50% used
  alertAt80    Boolean      @default(true)       // notify when 80% used
  alertAt100   Boolean      @default(true)       // notify when 100% used / exceeded
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([userId])
  @@map("budgets")
}

// ============================================================
// INVITE
// Invite non-app users to join via email or phone
// ============================================================

model Invite {
  id               Int          @id @default(autoincrement())
  email            String?
  phone            String?
  invitedById      Int
  invitedBy        User         @relation("InvitesSent", fields: [invitedById], references: [id])
  registeredUserId Int?
  registeredUser   User?        @relation("InvitesReceived", fields: [registeredUserId], references: [id])
  status           InviteStatus @default(PENDING)
  expiresAt        DateTime
  createdAt        DateTime     @default(now())

  @@index([invitedById])
  @@map("invites")
}

// ============================================================
// NOTIFICATION
// All in-app notifications with type enum for deep-linking
// ============================================================

model Notification {
  id         Int              @id @default(autoincrement())
  userId     Int                                     // who receives this notification
  user       User             @relation("NotificationReceiver", fields: [userId], references: [id], onDelete: Cascade)
  senderId   Int?                                    // who triggered it (null = system)
  sender     User?            @relation("NotificationSender", fields: [senderId], references: [id])
  type       NotificationType
  title      String
  message    String
  entityType String?                                 // "expense" | "group" | "settlement" | "friend" | "budget"
  entityId   Int?                                    // ID of the entity — used for deep-link navigation
  metadata   Json?                                   // extra data: {amount, currency, groupName, etc.}
  isRead     Boolean          @default(false)
  createdAt  DateTime         @default(now())

  @@index([userId])
  @@index([createdAt])
  @@map("notifications")
}
